# https://editorconfig.org

root = true

[*]
indent_style = tab
indent_size = tab
tab_width = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[CHANGELOG.md]
indent_style = space
indent_size = 2

[README.md]
indent_style=space
indent_size = 2

[LICENSE]
indent_style = space
indent_size = 4
